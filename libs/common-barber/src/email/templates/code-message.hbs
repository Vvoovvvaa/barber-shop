<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />

  <style>
    body {
      margin: 0;
      padding: 0;
      background: #0b0d12;
      font-family: Arial, Helvetica, sans-serif;
    }

    .card {
      border: 1px solid #262b36;
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.3s ease;
    }

    .card:hover {
      transform: translateY(-3px);
      box-shadow: 0 20px 60px rgba(79,70,229,0.25);
    }

    .code {
      letter-spacing: 8px;
      font-size: 34px;
      font-weight: 700;
      color: #4f46e5;
      background: #0b0d12;
      border: 1px solid #2a2f3a;
      border-radius: 12px;
      padding: 16px 22px;
      display: inline-block;
      box-shadow: 0 0 25px rgba(79,70,229,0.25);
    }

    .contact-btn {
      transition: all 0.2s ease;
    }

    .contact-btn:hover {
      transform: scale(1.05);
      opacity: 0.9;
    }
  </style>
</head>

<body>

  <table width="100%" cellpadding="0" cellspacing="0" style="padding:60px 0;">
    <tr>
      <td align="center">

        <table class="card" width="480" cellpadding="0" cellspacing="0"
          style="background:#141821;">

          <!-- TOP GRADIENT -->
          <tr>
            <td style="height:4px;
              background:linear-gradient(90deg,#4f46e5,#22c55e,#4f46e5);
              background-size:200% 200%;">
            </td>
          </tr>

          <!-- TITLE -->
          <tr>
            <td style="padding:26px; text-align:center;">
              <h2 style="margin:0; color:#fff; font-size:20px;">
                Verification Code
              </h2>
            </td>
          </tr>

          <!-- GIF -->
          <tr>
            <td align="center" style="padding-bottom:10px;">
              <img src="https://media.giphy.com/media/3o7TKtnuHOHHUjR38Y/giphy.gif"
                   width="110"
                   style="border-radius:12px; opacity:0.95;" />
            </td>
          </tr>

          <!-- TEXT -->
          <tr>
            <td style="text-align:center; padding:10px 30px; color:#8b95a7;">

              <h3 style="margin:0 0 10px; color:#fff; font-size:16px;">
                Hello, {{name}} 👋
              </h3>

              <p style="font-size:13px; line-height:1.6;">
                Use the code below to verify your account.  
                Do not share it with anyone.
              </p>

              <!-- CODE -->
              <div style="margin:25px 0;">
                <span class="code">{{code}}</span>
              </div>

              <p style="font-size:11px; color:#6b7280;">
                This code expires in a few minutes.
              </p>

            </td>
          </tr>

          <!-- CONTACT -->
          <tr>
            <td align="center" style="padding:25px 20px;">

              <p style="margin:0 0 10px; font-size:11px; color:#6b7280;">
                CONTACT
              </p>

              <a href="https://t.me/Vov_Markosyan"
                 class="contact-btn"
                 style="display:inline-block; margin:6px; padding:10px 18px;
                 background:#229ED9; color:#fff; text-decoration:none;
                 border-radius:10px; font-size:13px;">
                 Telegram
              </a>

              <a href="https://www.instagram.com/vov_markosyann/"
                 class="contact-btn"
                 style="display:inline-block; margin:6px; padding:10px 18px;
                 background:#E1306C; color:#fff; text-decoration:none;
                 border-radius:10px; font-size:13px;">
                 Instagram
              </a>

            </td>
          </tr>

          <!-- FOOTER -->
          <tr>
            <td style="text-align:center; padding:16px;
              font-size:11px; color:#6b7280;
              border-top:1px solid #262b36;">
              © {{year}} Secure System
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>