generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Review {
  id            String @id @default(uuid())
  appointmentId String @unique
  clientId      String
  barberId      String
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())
}